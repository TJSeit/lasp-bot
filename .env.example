# Local FAISS index directory (produced by indexer/build_index.py)
FAISS_INDEX_DIR=lasp_faiss_index

# Ollama server
OLLAMA_BASE_URL=http://localhost:11434
# Model name as it appears in `ollama list` (e.g. llama3, mistral, gemma3)
OLLAMA_MODEL=llama3

# Embedding model (must be the same for indexer and app)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Retrieval — number of chunks returned per query
TOP_K=5

# Chunking (indexer only)
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Discord bot (required only when running discord_bot.py)
DISCORD_TOKEN=your_discord_bot_token_here
# Command prefix for Discord (default: !)
DISCORD_COMMAND_PREFIX=!
