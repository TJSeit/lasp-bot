# Local FAISS index directory (produced by indexer/build_index.py)
# Set this to the path where build_index.py saved the index.
# Use an absolute path or a path relative to the app/ directory.
# Examples:
#   Linux/macOS: FAISS_INDEX_DIR=../indexer/lasp_faiss_index
#   Windows:     FAISS_INDEX_DIR=C:/Users/you/lasp-bot/indexer/lasp_faiss_index
FAISS_INDEX_DIR=lasp_faiss_index

# Ollama server
OLLAMA_BASE_URL=http://localhost:11434
# Model name as it appears in `ollama list` (e.g. llama3, mistral, gemma3)
OLLAMA_MODEL=llama3

# Embedding model (must be the same for indexer and app)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Retrieval — number of chunks returned per query
TOP_K=5

# Chunking (indexer only)
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Discord bot (required only when running discord_bot.py)
DISCORD_TOKEN=your_discord_bot_token_here
# Command prefix for Discord (default: !)
DISCORD_COMMAND_PREFIX=!

# MMS SDC MCP tool (mms_sdc_mcp.py / lasp_mcp.py)
# Base URL for the MMS Science Data Center public REST API
MMS_SDC_BASE_URL=https://lasp.colorado.edu/mms/sdc/public/files/api/v1
# HTTP request timeout in seconds (default: 30)
MMS_SDC_TIMEOUT=30

# LISIRD MCP tool (lisird_mcp.py / lasp_mcp.py)
# Base URL for the LaTiS DAP2 API used by LISIRD and the Space Weather Data Portal
LISIRD_BASE_URL=https://lasp.colorado.edu/lisird/latis/dap2
# HTTP request timeout in seconds (default: 30)
LISIRD_TIMEOUT=30

# AIM CIPS MCP tool (lasp_mcp.py)
# Base URL for the AIM mission LaTiS DAP2 API (noctilucent cloud data)
AIM_BASE_URL=https://lasp.colorado.edu/aim/latis/dap2
# HTTP request timeout in seconds (default: 30)
AIM_TIMEOUT=30

# HAPI MCP tool (lasp_mcp.py)
# HTTP request timeout in seconds for HAPI server requests (default: 30)
# The server URL is supplied per-call via the hapi_time_series_stream tool parameter.
HAPI_TIMEOUT=30
