# Azure Blob Storage — stores the FAISS index
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_NAME=lasp-index

# Azure AI Foundry Serverless API
# Endpoint format: https://<deployment-name>.<region>.models.ai.azure.com
AZURE_AI_ENDPOINT=https://your-deployment.eastus.models.ai.azure.com
AZURE_AI_API_KEY=your_api_key_here
# Model name — e.g. "Meta-Llama-3-8B-Instruct" or "gpt-4o-mini"
AZURE_AI_MODEL=Meta-Llama-3-8B-Instruct

# Embedding model (must be the same for indexer and app)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# FAISS index prefix inside the blob container
INDEX_BLOB_PREFIX=faiss_index

# Retrieval — number of chunks returned per query
TOP_K=5

# Chunking (indexer only)
CHUNK_SIZE=512
CHUNK_OVERLAP=64
